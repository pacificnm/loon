#!/usr/bin/env bash
set -euo pipefail

DESKTOP_ROOT="$(cd "$(dirname "$0")" && pwd)"
LOON_ROOT="$(cd "$DESKTOP_ROOT/.." && pwd)"
export CARGO_TARGET_DIR="${CARGO_TARGET_DIR:-$LOON_ROOT/target}"
export RUSTFLAGS="${RUSTFLAGS:--D warnings}"

cd "$DESKTOP_ROOT"

cmd="${1:-build}"
shift || true

case "$cmd" in
  build)
    cargo build -p loon-admin "$@"
    ;;
  release)
    cargo build -p loon-admin --release "$@"
    ;;
  run)
    profile=debug
    if [[ "${1:-}" == "--release" ]]; then
      profile=release
      shift
    fi
    bin="$LOON_ROOT/target/$profile/loon-admin"
    if [[ ! -x "$bin" ]]; then
      if [[ "$profile" == release ]]; then
        cargo build -p loon-admin --release
      else
        cargo build -p loon-admin
      fi
    fi
    config_args=()
    if [[ -f "$DESKTOP_ROOT/config.toml" ]]; then
      config_args=(--config "$DESKTOP_ROOT/config.toml")
    fi
    if [[ "${1:-}" == "--" ]]; then
      shift
    fi
    exec "$bin" "${config_args[@]}" "$@"
    ;;
  test)
    cargo test --workspace -- --test-threads=1 "$@"
    ;;
  check)
    cargo fmt --all -- --check
    cargo clippy --workspace -- -D warnings
    cargo test --workspace -- --test-threads=1
    cargo build -p loon-admin --release
    ;;
  *)
    cargo "$cmd" "$@"
    ;;
esac
