#!/usr/bin/env bash
# Loon Admin Desktop — Tauri + React. Standard Nest ./build interface.
set -euo pipefail

APP_ROOT="$(cd "$(dirname "$0")" && pwd)"
NEST_ROOT="$(cd "$APP_ROOT/../../.." && pwd)"

# shellcheck source=/dev/null
source "$NEST_ROOT/scripts/nest-build/lib.sh"

export NEST_BUILD_PROFILE=tauri
export NEST_UI_DIR=ui
export NEST_CARGO_MANIFEST=src-tauri/Cargo.toml
export NEST_RUST_PACKAGE=loon-desktop
export NEST_RUST_BIN=loon-desktop
export NEST_TAURI_MODE=binary

nest_build_main "$@"
