#!/usr/bin/env bash
# Loon — Rust server workspace. Standard Nest ./build interface.
set -euo pipefail

APP_ROOT="$(cd "$(dirname "$0")" && pwd)"
NEST_ROOT="$(cd "$APP_ROOT/../.." && pwd)"

# shellcheck source=/dev/null
source "$NEST_ROOT/scripts/nest-build/lib.sh"

cmd="${1:-build}"
if [[ "$cmd" == desktop ]]; then
  shift || true
  exec "$APP_ROOT/desktop/build" "$@"
fi

export NEST_BUILD_PROFILE=rust
export NEST_RUST_PACKAGE=loon-server
export NEST_RUST_BIN=loon-server

nest_build_main "$@"
